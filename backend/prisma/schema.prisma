generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                      String                   @id @default(uuid())
  email                   String                   @unique
  passwordHash            String
  displayName             String
  currentStreak           Int                      @default(0)
  lastLogDate             String?
  carbonScore             Int                      @default(0)
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  profile                 UserProfile?
  footprintEntries        FootprintEntry[]
  carbonTwinProfile       CarbonTwinProfile?
  carbonTwinSimulations   CarbonTwinSimulation[]
  actionPlans             ActionPlan[]
  recommendations         Recommendation[]
  userChallenges          UserChallenge[]
  userBadges              UserBadge[]
  aiConversations         AiConversation[]

  @@map("users")
}

model UserProfile {
  id            String   @id @default(uuid())
  userId        String   @unique
  country       String
  householdSize Int
  homeType      String
  dietType      String
  transportMode String
  energySource  String
  goalReason    String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_profiles")
}

model EmissionCategory {
  id              String           @id @default(uuid())
  name            String
  slug            String           @unique
  description     String
  emissionFactors EmissionFactor[]
  footprintEntries FootprintEntry[]
  recommendations Recommendation[]
  challenges      Challenge[]

  @@map("emission_categories")
}

model EmissionFactor {
  id               String            @id @default(uuid())
  categoryId       String
  activityType     String
  unit             String
  kgCo2ePerUnit    Decimal           @db.Decimal(10, 4)
  source           String
  category         EmissionCategory  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  footprintEntries FootprintEntry[]

  @@index([categoryId, activityType])
  @@map("emission_factors")
}

model FootprintEntry {
  id               String           @id @default(uuid())
  userId           String
  categoryId       String
  emissionFactorId String
  activityType     String
  quantity         Decimal          @db.Decimal(12, 2)
  unit             String
  kgCo2e           Decimal          @db.Decimal(12, 2)
  occurredAt       DateTime
  notes            String?
  createdAt        DateTime         @default(now())
  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  category         EmissionCategory @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  emissionFactor   EmissionFactor   @relation(fields: [emissionFactorId], references: [id], onDelete: Restrict)

  @@index([userId, occurredAt])
  @@index([userId, categoryId])
  @@map("footprint_entries")
}

model CarbonTwinProfile {
  id                    String   @id @default(uuid())
  userId                String   @unique
  baselineKgCo2eMonthly Decimal  @db.Decimal(12, 2)
  topEmissionSource     String
  biggestOpportunity    String
  userGoal              String
  userConstraints       String
  summary               String
  updatedAt             DateTime @updatedAt
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("carbon_twin_profiles")
}

model CarbonTwinSimulation {
  id                     String   @id @default(uuid())
  userId                 String
  scenarioName           String
  days                   Int
  projectedKgCo2e        Decimal  @db.Decimal(12, 2)
  estimatedSavingsKgCo2e Decimal  @db.Decimal(12, 2)
  assumptions            Json
  createdAt              DateTime @default(now())
  user                   User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("carbon_twin_simulations")
}

model ActionPlan {
  id        String           @id @default(uuid())
  userId    String
  title     String
  summary   String
  startDate DateTime
  endDate   DateTime
  status    String           @default("Active")
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     ActionPlanItem[]

  @@index([userId, status])
  @@map("action_plans")
}

model ActionPlanItem {
  id                       String     @id @default(uuid())
  actionPlanId             String
  dayNumber                Int
  title                    String
  description              String
  category                 String
  estimatedSavingsKgCo2e   Decimal    @db.Decimal(12, 2)
  difficulty               String
  status                   String     @default("Pending")
  actionPlan               ActionPlan @relation(fields: [actionPlanId], references: [id], onDelete: Cascade)

  @@index([actionPlanId, dayNumber])
  @@unique([actionPlanId, dayNumber])
  @@map("action_plan_items")
}

model Recommendation {
  id                       String           @id @default(uuid())
  userId                   String
  categoryId               String
  title                    String
  description              String
  estimatedSavingsKgCo2e   Decimal          @db.Decimal(12, 2)
  difficulty               String
  status                   String           @default("New")
  source                   String
  createdAt                DateTime         @default(now())
  user                     User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  category                 EmissionCategory @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  @@index([userId, status])
  @@unique([userId, title])
  @@map("recommendations")
}

model Challenge {
  id             String           @id @default(uuid())
  title          String
  description    String
  categoryId      String
  difficulty      String
  points          Int
  durationDays    Int
  category        EmissionCategory @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  userChallenges  UserChallenge[]

  @@map("challenges")
}

model UserChallenge {
  id            String    @id @default(uuid())
  userId        String
  challengeId   String
  status        String    @default("Joined")
  progressValue Int       @default(0)
  startedAt     DateTime  @default(now())
  completedAt   DateTime?
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  challenge     Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)

  @@unique([userId, challengeId])
  @@map("user_challenges")
}

model Badge {
  id          String      @id @default(uuid())
  name        String
  description String
  iconKey     String
  ruleKey     String      @unique
  userBadges  UserBadge[]

  @@map("badges")
}

model UserBadge {
  id        String   @id @default(uuid())
  userId    String
  badgeId   String
  awardedAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge     Badge    @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeId])
  @@map("user_badges")
}

model AiConversation {
  id        String      @id @default(uuid())
  userId    String
  title     String
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages  AiMessage[]

  @@index([userId, updatedAt])
  @@map("ai_conversations")
}

model AiMessage {
  id             String         @id @default(uuid())
  conversationId String
  role           String
  content        String
  model          String
  createdAt      DateTime       @default(now())
  conversation   AiConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@map("ai_messages")
}
